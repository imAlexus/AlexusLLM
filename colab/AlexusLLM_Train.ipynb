    "# 4) Training (su GPU Colab e veloce)\n",
    "!python train.py --data data/sample.txt --epochs 5 --device cuda --dim 384 --n_layers 8"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 5) Chat di test\n",
    "# NOTA: chat.py e interattivo; qui facciamo un giro non interattivo\n",
    "import torch\n",
    "from model import TransformerLM\n",
    "from tokenizer import Tokenizer\n",
    "\n",
    "ckpt = torch.load('checkpoints/model.pt', map_location='cpu')\n",
    "tok = Tokenizer(); tok.load('checkpoints/tokenizer.json')\n",
    "m = TransformerLM(vocab_size=ckpt['vocab_size'], dim=ckpt['dim'],\n",
    "                  n_layers=ckpt['n_layers'], n_heads=ckpt['n_heads'],\n",
    "                  block_size=ckpt['block_size'])\n",
    "m.load_state_dict(ckpt['model']); m.eval()\n",
    "\n",
    "def ask(prompt):\n",
    "    ctx = f'USER: {prompt}\\nASSISTANT:'\n",
    "    ids = tok.encode(ctx)\n",
    "    x = torch.tensor(ids)[None, :]\n",
    "    out = m.generate(x, 120, temperature=0.8, top_k=40)\n",
    "    reply = tok.decode(out[0].tolist()[len(ids):]).split('USER:')[0].strip()\n",
    "    print('IA:', reply)\n",
    "\n",
    "for q in ['Ciao, come stai?', 'Quanto fa 17 piu 25?', 'Spiegami cosa e una rete neurale.']:\n",
    "    print('TU:', q); ask(q)"
   ]
  }
